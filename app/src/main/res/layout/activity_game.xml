<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cyberpunk">
    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="65dp"
        android:text="←"
        android:textColor="#80D4FF"
        android:textSize="35sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TIC TAC TOE PRO"
        android:textColor="#80D4FF"
        android:shadowColor="#FF007F"
        android:shadowRadius="45"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="@font/orbitron"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Score Panel -->

    <LinearLayout
        android:id="@+id/scorePanel"
        android:layout_width="0dp"

        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:background="@drawable/neon_border"
        android:padding="16dp"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="#00E5FF"
                android:textSize="24sp"/>

            <TextView
                android:id="@+id/txtXScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="20sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="ROUND"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◯"
                android:textStyle="bold"
                android:textColor="#FF007F"
                android:textSize="24sp"/>

            <TextView
                android:id="@+id/txtOScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="20sp"/>
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/txtTurn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PLAYER X TURN"
        android:textColor="#00E5FF"
        android:layout_marginTop="10dp"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/scorePanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/boardContainer"
        android:layout_width="340dp"
        android:layout_height="340dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#0A0A15"
        app:cardCornerRadius="30dp"
        app:strokeWidth="3dp"
        app:strokeColor="#80D4FF"
        app:layout_constraintTop_toBottomOf="@id/txtTurn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <GridLayout
            android:id="@+id/gameBoard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="3"
            android:rowCount="3"
            android:padding="8dp">

            <Button
                android:id="@+id/cell0"
                android:shadowColor="#FF007F"
                style="@style/GameCell"/>

            <Button
                android:id="@+id/cell1"
                style="@style/GameCell"/>

            <Button
                android:id="@+id/cell2"
                style="@style/GameCell"/>

            <Button
                android:id="@+id/cell3"
                style="@style/GameCell"/>

            <Button
                android:id="@+id/cell4"
                style="@style/GameCell"/>

            <Button
                android:id="@+id/cell5"
                style="@style/GameCell"/>

            <Button
                android:id="@+id/cell6"
                style="@style/GameCell"/>

            <Button
                android:id="@+id/cell7"
                style="@style/GameCell"/>

            <Button
                android:id="@+id/cell8"
                style="@style/GameCell"/>

        </GridLayout>

    </com.google.android.material.card.MaterialCardView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnNewRound"
        android:layout_width="280dp"
        android:layout_height="55dp"
        android:layout_marginTop="52dp"
        android:background="@drawable/neon_button"
        android:fontFamily="@font/orbitron"
        android:text="↻ NEW ROUND"
        android:textAllCaps="false"
        android:textColor="#00E5FF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.503"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/boardContainer" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnReset"
        android:layout_width="280dp"
        android:layout_height="55dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/neon_button"
        android:fontFamily="@font/orbitron"
        android:text="⚡ RESET SCORES"
        android:textAllCaps="false"
        android:textColor="#FF007F"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.503"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnNewRound" />

</androidx.constraintlayout.widget.ConstraintLayout>