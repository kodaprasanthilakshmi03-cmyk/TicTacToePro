<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cyberpunk">

    <!-- Neon Border -->

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:background="@drawable/neon_border"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Title -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TIC TAC TOE&#10;PRO"
        android:textAlignment="center"
        android:gravity="center"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#80D4FF"
        android:fontFamily="@font/orbitron"
        android:shadowColor="#FF007F"
        android:shadowRadius="25"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/txtTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Challenge • Strategy • Win"
        android:textColor="#8BE9FD"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Play Friend -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFriend"
        android:layout_width="300dp"
        android:layout_height="75dp"
        android:layout_marginTop="70dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeColor="#00E5FF"
        app:strokeWidth="2dp"
        app:cardCornerRadius="18dp"
        app:layout_constraintTop_toBottomOf="@id/txtTag"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="👥 PLAY VS FRIEND"
            android:textColor="#00E5FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron"/>

    </com.google.android.material.card.MaterialCardView>

    <!-- Play AI -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardAI"
        android:layout_width="300dp"
        android:layout_height="75dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeColor="#FF007F"
        app:strokeWidth="2dp"
        app:cardCornerRadius="18dp"
        app:layout_constraintTop_toBottomOf="@id/cardFriend"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🤖 PLAY VS AI"
            android:textColor="#FF007F"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron"/>

    </com.google.android.material.card.MaterialCardView>

    <!-- Statistics -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStats"
        android:layout_width="300dp"
        android:layout_height="75dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeColor="#00E5FF"
        app:strokeWidth="2dp"
        app:cardCornerRadius="18dp"
        app:layout_constraintTop_toBottomOf="@id/cardAI"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🏆 STATISTICS"
            android:textColor="#00E5FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron"/>

    </com.google.android.material.card.MaterialCardView>

    <!-- Settings -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSettings"
        android:layout_width="300dp"
        android:layout_height="75dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeColor="#FF007F"
        app:strokeWidth="2dp"
        app:cardCornerRadius="18dp"
        app:layout_constraintTop_toBottomOf="@id/cardStats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="⚙ SETTINGS"
            android:textColor="#FF007F"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron"/>

    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Controls -->

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnSound"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_margin="8dp"
            android:background="@drawable/neon_circle"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:tint="#00E5FF"/>

        <ImageButton
            android:id="@+id/btnInfo"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_margin="8dp"
            android:background="@drawable/neon_circle"
            android:src="@android:drawable/ic_dialog_info"
            android:tint="#00E5FF"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>