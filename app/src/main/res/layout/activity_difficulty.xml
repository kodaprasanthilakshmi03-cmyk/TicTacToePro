<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cyberpunk">

    <TextView
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="96dp"
        android:text="←"
        android:textColor="#80D4FF"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SELECT&#10;DIFFICULTY"
        android:textAlignment="center"
        android:gravity="center"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#80D4FF"
        android:fontFamily="@font/orbitron"
        android:shadowColor="#FF007F"
        android:shadowRadius="25"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardEasy"
        android:layout_width="280dp"
        android:layout_height="80dp"
        android:layout_marginTop="80dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeColor="#00FF88"
        android:textColor="#80D4FF"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="#FF007F"
            android:text="🟢 EASY"
            android:fontFamily="@font/orbitron"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMedium"
        android:layout_width="280dp"
        android:layout_height="80dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeColor="#FFD700"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/cardEasy"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="#FF007F"
            android:fontFamily="@font/orbitron"
            android:text="🟡 MEDIUM"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHard"
        android:layout_width="280dp"
        android:layout_height="80dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:strokeColor="#FF0000"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/cardMedium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="#FF007F"
            android:fontFamily="@font/orbitron"
            android:text="🔴 HARD"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>